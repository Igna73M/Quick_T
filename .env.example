# Environment Configuration
NODE_ENV=development

# Database Configuration
DATABASE_URL=mongodb://localhost:27017/quick_t_dev
# or for PostgreSQL: postgresql://username:password@localhost:5432/quick_t_dev

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Server Configuration
PORT=5000
CLIENT_URL=http://localhost:3000

# Email Configuration (optional)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Google Maps API (for transport routes)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Stripe/Payment Configuration (if needed)
STRIPE_PUBLIC_KEY=pk_test_your-stripe-public-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# File Upload Configuration
MAX_FILE_SIZE=5000000
UPLOAD_PATH=./uploads

# Redis Configuration (for sessions/caching)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=debug